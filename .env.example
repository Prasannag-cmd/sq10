# Google Places API integration (for real-time Google Reviews)
# Get a Google Maps Javascript API Key from Google Cloud Console
VITE_GOOGLE_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Google Place ID for Squaareten Construction Madurai
# Find your Place ID at: https://developers.google.com/maps/documentation/javascript/examples/places-placeid-finder
VITE_GOOGLE_PLACE_ID=ChIJd39999999999999
